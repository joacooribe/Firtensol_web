---
import Layout from "../../layouts/Layout.astro";
import { Navbar } from "../../components/Navbar";
import { Footer } from "../../components/Footer";
import { PageHeader } from "../../components/PageHeader";
import { useTranslations } from "../../i18n/utils";

export function getStaticPaths() {
	return [{ params: { lang: "es" } }, { params: { lang: "en" } }];
}

const { lang } = Astro.params as { lang: "es" | "en" };
const t = useTranslations(lang);
---

<Layout title={t("nav.aboutUs")}>
	<Navbar client:load lang={lang} />

	<main>
		<PageHeader title={t("nav.aboutUs")} subtitle={t("about.subtitle")} />

		<section class="py-24 bg-white">
			<div class="container mx-auto px-6">
				<div class="flex flex-col lg:flex-row gap-16 items-center">
					<div class="lg:w-1/2">
						<div class="rounded-3xl overflow-hidden shadow-2xl">
							<img
								src="/img/nuestra historia.webp"
								alt="Nuestra Historia"
								class="w-full object-cover aspect-video"
							/>
						</div>
					</div>
					<div class="lg:w-1/2">
						<h2
							class="text-3xl font-heading font-bold text-primary mb-6"
						>
							Nuestra Historia
						</h2>
						<p class="text-slate-600 text-lg leading-relaxed mb-6">
							{t("about.history")}
						</p>
						<p class="text-slate-600 text-lg leading-relaxed">
							Desde nuestros comienzos en 2006, nos hemos enfocado
							en brindar soluciones de alta precisión para el
							sector agroindustrial, convirtiéndonos en un
							referente regional en el Hub Logístico del Río de la
							Plata.
						</p>
					</div>
				</div>
			</div>
		</section>

		<section class="py-24 bg-slate-50">
			<div class="container mx-auto px-6 text-center mb-16">
				<h2 class="text-3xl font-heading font-bold text-primary mb-4">
					Misión y Visión
				</h2>
				<p class="text-slate-500 max-w-2xl mx-auto">
					Nuestro propósito y el futuro que construimos cada día.
				</p>
			</div>
			<div
				class="container mx-auto px-6 grid grid-cols-1 md:grid-cols-2 gap-12"
			>
				<div
					class="bg-white p-12 rounded-3xl shadow-sm border border-slate-100"
				>
					<div
						class="w-12 h-12 bg-accent/20 rounded-xl flex items-center justify-center text-accent mb-8"
					>
						<svg
							xmlns="http://www.w3.org/2000/svg"
							width="24"
							height="24"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="2"
							stroke-linecap="round"
							stroke-linejoin="round"
							><circle cx="12" cy="12" r="10"></circle><circle
								cx="12"
								cy="12"
								r="2"></circle></svg
						>
					</div>
					<h3 class="text-2xl font-bold text-primary mb-4">Misión</h3>
					<p class="text-slate-600 leading-relaxed text-lg italic">
						"{t("about.mission")}"
					</p>
				</div>
				<div
					class="bg-white p-12 rounded-3xl shadow-sm border border-slate-100"
				>
					<div
						class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center text-primary mb-8"
					>
						<svg
							xmlns="http://www.w3.org/2000/svg"
							width="24"
							height="24"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="2"
							stroke-linecap="round"
							stroke-linejoin="round"
							><path
								d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"
							></path><circle cx="12" cy="12" r="3"></circle></svg
						>
					</div>
					<h3 class="text-2xl font-bold text-primary mb-4">Visión</h3>
					<p class="text-slate-600 leading-relaxed text-lg italic">
						"{t("about.vision")}"
					</p>
				</div>
			</div>
		</section>

		<section class="py-24 bg-white">
			<div class="container mx-auto px-6 text-center mb-16">
				<h2 class="text-3xl font-heading font-bold text-primary mb-4">
					Nuestros Valores
				</h2>
				<p class="text-slate-500 max-w-2xl mx-auto">
					Los pilares que guían cada una de nuestras acciones.
				</p>
			</div>
			<div
				class="container mx-auto px-6 grid grid-cols-2 md:grid-cols-4 gap-8"
			>
				{
					["integrity", "excellence", "innovation", "commitment"].map(
						(val) => (
							<div class="text-center p-8 rounded-2xl bg-slate-50 border border-slate-100 group hover:bg-primary hover:text-white transition-all duration-300">
								<h3 class="text-xl font-bold mb-2 uppercase tracking-wide">
									{t(`about.values.${val}`)}
								</h3>
							</div>
						),
					)
				}
			</div>
		</section>

		<Footer client:visible lang={lang} />
	</main>
</Layout>
