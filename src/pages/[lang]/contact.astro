---
import Layout from '../../layouts/Layout.astro';
import { Navbar } from '../../components/Navbar';
import { Footer } from '../../components/Footer';
import { PageHeader } from '../../components/PageHeader';
import { Contact as ContactForm } from '../../components/Contact';
import { useTranslations } from '../../i18n/utils';

export function getStaticPaths() {
  return [
    { params: { lang: 'es' } },
    { params: { lang: 'en' } },
  ];
}

const { lang } = Astro.params as { lang: 'es' | 'en' };
const t = useTranslations(lang);
---

<Layout title={t('nav.contact')}>
	<Navbar client:load lang={lang} />
	
	<main>
		<PageHeader 
			title={t('nav.contact')} 
			subtitle="Estamos a su disposición para cualquier consulta o requerimiento técnico." 
		/>

		<ContactForm client:visible lang={lang} />

		<section class="py-24 bg-white">
			<div class="container mx-auto px-6">
				<div class="grid grid-cols-1 md:grid-cols-3 gap-12">
					<div class="text-center p-8 rounded-3xl bg-slate-50 border border-slate-100">
						<div class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center text-primary mx-auto mb-6">
							<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
						</div>
						<h3 class="font-bold text-xl text-primary mb-2">Comercial</h3>
						<p class="text-slate-500">Para cotizaciones y consultas comerciales.</p>
						<a href="mailto:comercial@fit.com.uy" class="text-accent font-bold mt-4 block underline">comercial@fit.com.uy</a>
					</div>
					<div class="text-center p-8 rounded-3xl bg-slate-50 border border-slate-100">
						<div class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center text-primary mx-auto mb-6">
							<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
						</div>
						<h3 class="font-bold text-xl text-primary mb-2">Operaciones</h3>
						<p class="text-slate-500">Coordinación de servicios y seguimiento técnico.</p>
						<a href="mailto:operaciones@fit.com.uy" class="text-accent font-bold mt-4 block underline">operaciones@fit.com.uy</a>
					</div>
					<div class="text-center p-8 rounded-3xl bg-slate-50 border border-slate-100">
						<div class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center text-primary mx-auto mb-6">
							<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
						</div>
						<h3 class="font-bold text-xl text-primary mb-2">Administración</h3>
						<p class="text-slate-500">Consultas administrativas y facturación.</p>
						<a href="mailto:administracion@fit.com.uy" class="text-accent font-bold mt-4 block underline">administracion@fit.com.uy</a>
					</div>
				</div>
			</div>
		</section>

		<Footer client:visible lang={lang} />
	</main>
</Layout>
