---
import Layout from "../../layouts/Layout.astro";
import { Navbar } from "../../components/Navbar";
import { Services } from "../../components/Services";
import { About } from "../../components/About";
import { Contact } from "../../components/Contact";
import { Footer } from "../../components/Footer";
import { useTranslations } from "../../i18n/utils";
import { FadeIn } from "../../components/FadeIn";

export function getStaticPaths() {
	return [{ params: { lang: "es" } }, { params: { lang: "en" } }];
}

const { lang } = Astro.params as { lang: "es" | "en" };
const t = useTranslations(lang);
---

<Layout title={t("hero.headline")}>
	<Navbar client:load lang={lang} />

	<main class="overflow-x-hidden">
		<!-- Hero Section -->
		<section
			class="relative min-h-[90vh] flex items-center pt-32 pb-20 overflow-hidden bg-slate-900"
		>
			{/* Video Background */}
			<div class="absolute inset-0 z-0">
				<video 
					autoplay 
					muted 
					loop 
					playsinline 
					class="w-full h-full object-cover opacity-60"
				>
					<source src="/img/hero section 2.mp4" type="video/mp4" />
				</video>
				<div class="absolute inset-0 bg-gradient-to-r from-primary via-primary/60 to-transparent"></div>
			</div>

			<div class="container mx-auto px-6 relative z-10">
				<div class="max-w-4xl">
					<FadeIn client:load delay={0.1} direction="up">
						<div
							class="inline-flex items-center gap-3 py-2 px-4 rounded-full bg-white/10 backdrop-blur-md border border-white/20 text-white text-[10px] font-bold uppercase tracking-[0.2em] mb-10 shadow-xl"
						>
							<span class="flex h-2 w-2 relative">
								<span
									class="animate-ping absolute inline-flex h-full w-full rounded-full bg-accent opacity-75"
								></span>
								<span
									class="relative inline-flex rounded-full h-2 w-2 bg-accent"
								></span>
							</span>
							{t("about.iso9001")}
						</div>
					</FadeIn>

					<FadeIn client:load delay={0.2} direction="up">
						<h1
							class="text-5xl md:text-8xl font-heading font-extrabold text-white leading-[1.05] mb-8 tracking-tighter"
						>
							{t("hero.headline")}
						</h1>
					</FadeIn>

					<FadeIn client:load delay={0.3} direction="up">
						<p
							class="text-xl md:text-2xl text-white/80 max-w-2xl mb-12 leading-relaxed"
						>
							{t("hero.subheadline")}
						</p>
					</FadeIn>

					<FadeIn client:load delay={0.4} direction="up">
						<div
							class="flex flex-wrap gap-5"
						>
							<a
								href={`/${lang}/services`}
								class="px-10 py-5 bg-accent text-white font-bold rounded-xl hover:bg-white hover:text-primary transition-all shadow-xl shadow-accent/20 hover:shadow-accent/40 hover:-translate-y-1 active:scale-95"
							>
								{t("hero.cta")}
							</a>
							<a
								href={`/${lang}/contact`}
								class="px-10 py-5 bg-white/10 backdrop-blur-md text-white border border-white/20 font-bold rounded-xl hover:bg-white/20 transition-all flex items-center gap-3 shadow-sm hover:shadow-md group"
							>
								{t("hero.contact")}
								<svg
									xmlns="http://www.w3.org/2000/svg"
									width="20"
									height="20"
									viewBox="0 0 24 24"
									fill="none"
									stroke="currentColor"
									stroke-width="2.5"
									stroke-linecap="round"
									stroke-linejoin="round"
									class="group-hover:translate-x-1 transition-transform text-accent"
									><line x1="5" y1="12" x2="19" y2="12"
									></line><polyline points="12 5 19 12 12 19"
									></polyline></svg
								>
							</a>
						</div>
					</FadeIn>
				</div>
			</div>
		</section>

		<Services client:visible lang={lang} />

		<About client:visible lang={lang} />

		<!-- Partners Section -->
		<section class="py-24 bg-slate-50/50 border-y border-slate-100">
			<div class="container mx-auto px-6">
				<div
					class="flex flex-col lg:flex-row items-center justify-between gap-16"
				>
					<div class="max-w-xs text-center lg:text-left">
						<FadeIn client:load direction="right">
							<h2
								class="text-[10px] font-bold uppercase tracking-[0.3em] text-slate-400 mb-3"
							>
								{t("about.partners.title")}
							</h2>
							<p
								class="text-primary font-extrabold text-xl leading-tight"
							>
								{t("about.partners.subtitle")}
							</p>
						</FadeIn>
					</div>
					<div
						class="flex flex-wrap justify-center items-center gap-12 md:gap-20"
					>
						<FadeIn client:load delay={0.2} direction="up">
							<a
								href="https://www.rmgcal.com"
								target="_blank"
								rel="noopener"
								class="opacity-60 hover:opacity-100 transition-all duration-500 grayscale hover:grayscale-0 block"
							>
								<img
									src="/img/rmg.jpg"
									alt="RMG"
									class="h-10 md:h-12 w-auto object-contain"
								/>
							</a>
						</FadeIn>
						<FadeIn client:load delay={0.3} direction="up">
							<a
								href="https://www.superinspect.com.br/"
								target="_blank"
								rel="noopener"
								class="opacity-60 hover:opacity-100 transition-all duration-500 grayscale hover:grayscale-0 block"
							>
								<img
									src="/img/logo_superinspect.svg"
									alt="Superinspect"
									class="h-8 md:h-10 w-auto object-contain"
								/>
							</a>
						</FadeIn>
						<FadeIn client:load delay={0.4} direction="up">
							<a
								href="https://www.trust-control.com/"
								target="_blank"
								rel="noopener"
								class="opacity-60 hover:opacity-100 transition-all duration-500 grayscale hover:grayscale-0 block"
							>
								<img
									src="/img/trust control.png"
									alt="Trust Control"
									class="h-10 md:h-12 w-auto object-contain"
								/>
							</a>
						</FadeIn>
					</div>
				</div>
			</div>
		</section>

		<Contact client:visible lang={lang} />

		<Footer client:visible lang={lang} />
	</main>
</Layout>
